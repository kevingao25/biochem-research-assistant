# PostgreSQL
POSTGRES_USER=biochem
POSTGRES_PASSWORD=changeme
POSTGRES_DB=biochem_research

# Airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here
AIRFLOW_ADMIN_PASSWORD=admin

# Qdrant
QDRANT_API_KEY=

# Jina AI (embeddings for semantic search)
JINA_API_KEY=your-jina-api-key-here

# API
API_SECRET_KEY=changeme

# Langfuse (LLM observability — get keys from cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Redis (answer cache — no key needed for local dev)
REDIS_URL=redis://redis:6379

# Agentic RAG
AGENT__MAX_RETRIEVAL_ATTEMPTS=2
AGENT__GUARDRAIL_ENABLED=true
